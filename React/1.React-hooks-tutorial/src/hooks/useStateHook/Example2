import { useState } from "react";

const App = () => {
  const [inputValue, setInputValue] = useState("");
  return (
    <div>
      <input
        type="text"
        placeholder="Type Something"
        value={inputValue}
        onChange={(e) => setInputValue(e.target.value)}
      />
      <p>
        You Typed: <strong>{inputValue}</strong>
      </p>
    </div>
  );
};

export default App;
